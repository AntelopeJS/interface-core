{
  "name": "@antelopejs/interface-core",
  "version": "0.0.1",
  "description": "AntelopeJS core interface primitives - proxies, decorators, interface functions, and logging",
  "keywords": [
    "antelopejs",
    "interface",
    "core"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/interface-core.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./logging": {
      "types": "./dist/logging/index.d.ts",
      "default": "./dist/logging/index.js"
    },
    "./logging/*": {
      "types": "./dist/logging/*.d.ts",
      "default": "./dist/logging/*.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "decorators": [
        "dist/decorators.d.ts"
      ],
      "modules": [
        "dist/modules.d.ts"
      ],
      "proxies": [
        "dist/proxies.d.ts"
      ],
      "internal": [
        "dist/internal.d.ts"
      ],
      "config": [
        "dist/config.d.ts"
      ],
      "logging": [
        "dist/logging/index.d.ts"
      ],
      "logging/*": [
        "dist/logging/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run prepack && release-it",
    "test": "pnpm run build && ajs module test ."
  },
  "antelopeJs": {
    "test": "src/antelope.test.ts"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.14.1",
    "chai": "^4.5.0",
    "release-it": "^19.0.2",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
